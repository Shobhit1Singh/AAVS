{
  "openapi": "3.0.0",
  "info": {
    "title": "Vulnerable API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "paths": {
    "/api/users": {
      "get": {
        "summary": "Get all users",
        "responses": {
          "200": {
            "description": "List users"
          }
        }
      }
    },
    "/api/login": {
      "post": {
        "summary": "Login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Success" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/api/user/{id}": {
      "get": {
        "summary": "Get user by ID (IDOR)",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "User data" }
        }
      }
    },
    "/api/update": {
      "post": {
        "summary": "Update user role (mass assignment)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": { "type": "integer" },
                  "role": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated" }
        }
      }
    },
    "/api/search": {
      "get": {
        "summary": "Search (reflected input)",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Search results" }
        }
      }
    },
    "/api/exec": {
      "post": {
        "summary": "Execute command (command injection)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "cmd": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Command output" }
        }
      }
    }
  }
}