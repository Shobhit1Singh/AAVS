{
  "openapi": "3.0.0",
  "info": {
    "title": "Advanced Vulnerable API",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "paths": {
    "/api/register": {
      "post": {
        "summary": "Register user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" },
                  "role": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Registered" }
        }
      }
    },
    "/api/login": {
      "post": {
        "summary": "Login and get JWT",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "JWT Token" }
        }
      }
    },
    "/api/refresh": {
      "post": {
        "summary": "Refresh JWT",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "refreshToken": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "New JWT" }
        }
      }
    },
    "/api/users": {
      "get": {
        "summary": "Get all users (requires auth)",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "List users" }
        }
      }
    },
    "/api/user/{id}": {
      "get": {
        "summary": "Get user by ID (IDOR)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "User data" }
        }
      }
    },
    "/api/update": {
      "post": {
        "summary": "Update user (mass assignment)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": { "type": "integer" },
                  "role": { "type": "string" },
                  "isAdmin": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated" }
        }
      }
    },
    "/api/admin": {
      "get": {
        "summary": "Admin panel (weak auth)",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Admin data" }
        }
      }
    },
    "/api/search": {
      "get": {
        "summary": "Search (XSS)",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Search results" }
        }
      }
    },
    "/api/upload": {
      "post": {
        "summary": "File upload (no validation)",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Uploaded" }
        }
      }
    },
    "/api/exec": {
      "post": {
        "summary": "Execute command (RCE)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "cmd": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Command output" }
        }
      }
    }
  }
}