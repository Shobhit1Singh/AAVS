{
  "openapi": "3.0.0",
  "info": {
    "title": "Ultra Vulnerable API",
    "version": "1.0.0",
    "description": "Intentionally vulnerable API for testing AAVS. Contains broken auth, IDOR, data leaks, injection, and more."
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "username": { "type": "string" },
          "password": { "type": "string" },
          "role": { "type": "string" },
          "email": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/api/login": {
      "post": {
        "summary": "Login and get JWT (leaks full user data)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Returns token and full user object (including password)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": { "type": "string" },
                    "user": {
                      "$ref": "#/components/schemas/User"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/user/{id}": {
      "get": {
        "summary": "Get user by ID (IDOR vulnerability)",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns user data without authorization check",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          }
        }
      }
    },
    "/api/update": {
      "post": {
        "summary": "Update user (mass assignment + privilege escalation)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": { "type": "integer" },
                  "username": { "type": "string" },
                  "password": { "type": "string" },
                  "role": { "type": "string" },
                  "email": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated user object"
          }
        }
      }
    },
    "/api/search": {
      "get": {
        "summary": "Search users (SQL Injection simulation)",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns filtered users or all users if injection detected",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/exec": {
      "post": {
        "summary": "Execute command (simulated RCE)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "cmd": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Command execution result",
            "content": {
              "text/plain": {
                "schema": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "/api/debug": {
      "get": {
        "summary": "Debug endpoint (sensitive data exposure)",
        "responses": {
          "200": {
            "description": "Returns internal data including secrets",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          }
        }
      }
    },
    "/api/admin": {
      "get": {
        "summary": "Admin access (broken JWT auth)",
        "security": [
          { "bearerAuth": [] }
        ],
        "responses": {
          "200": {
            "description": "Admin access granted"
          },
          "403": {
            "description": "Forbidden"
          }
        }
      }
    }
  },
  "security": [
    { "bearerAuth": [] }
  ]
}